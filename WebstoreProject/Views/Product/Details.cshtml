@model WebstoreProject.Models.Product
@using System.Globalization

@{
    ViewData["Title"] = Model.Name;

    decimal priceToUse = Model.HasDiscount ? Model.DiscountedPrice : Model.Price;

    string priceToUseText = priceToUse.ToString("0.00", CultureInfo.InvariantCulture);
    string normalPriceText = Model.Price.ToString("0.00", CultureInfo.InvariantCulture);
    string discountedText = Model.DiscountedPrice.ToString("0.00", CultureInfo.InvariantCulture);

    string? unitPriceText = Model.UnitPrice.HasValue
        ? Model.UnitPrice.Value.ToString("0.00", CultureInfo.InvariantCulture)
        : null;
}

<div class="container my-4">

    <!-- augsa -->
    <div class="small text-muted mb-3">
        <i class="bi bi-house me-1"></i>
        <a asp-controller="Home" asp-action="Index" class="text-decoration-none">Home</a>

        @if (Model.Category != null)
        {
            @: ›
            @if (Model.Category.Parent != null)
            {
                <a class="text-decoration-none"
                   asp-controller="Products"
                   asp-action="Index"
                   asp-route-categoryId="@Model.Category.Parent.CategoryId">
                    @Model.Category.Parent.Name
                </a>
                @: ›
            }

            <a class="text-decoration-none"
               asp-controller="Products"
               asp-action="Index"
               asp-route-categoryId="@Model.Category.CategoryId">
                @Model.Category.Name
            </a>
        }

        <span>›</span>
        <strong>@Model.Name</strong>
    </div>

    <!-- produkts -->
    <div class="row mb-4">
        <!-- bildite -->
        <div class="col-md-5 text-center">
            <img src="@(string.IsNullOrWhiteSpace(Model.ImageUrl)
                ? "https://via.placeholder.com/400x400?text=Product"
                : Model.ImageUrl)"
                 class="img-fluid"
                 style="max-height:420px; object-fit:contain; background:#fff;"
                 alt="@Model.Name" />
        </div>

        <!-- info -->
        <div class="col-md-7">
            <h2 class="mb-2">@Model.Name</h2>

            <div class="text-muted mb-2">
                @if (Model.Brand != null)
                {
                    <i class="bi bi-tag me-1"></i>
                    <span>@Model.Brand.Name</span>
                    <span class="mx-2">•</span>
                }
                <i class="bi bi-box me-1"></i>
                <span>@Model.UnitText</span>
            </div>

            <!-- cena -->
            <div class="mb-3">
                @if (Model.HasDiscount)
                {
                    <div>
                        <span class="fs-3 fw-bold text-danger">
                            <i class="bi bi-currency-euro"></i>@discountedText
                        </span>
                        <span class="text-muted text-decoration-line-through ms-2">
                            €@normalPriceText
                        </span>
                        <span class="badge bg-danger ms-2">
                            -@Model.DiscountPercent%
                        </span>
                    </div>
                }
                else
                {
                    <div class="fs-3 fw-bold">
                        <i class="bi bi-currency-euro"></i>@normalPriceText
                    </div>
                }

                @if (Model.UnitPrice.HasValue && !string.IsNullOrWhiteSpace(Model.UnitPriceLabel))
                {
                    <div class="text-muted">
                        <i class="bi bi-calculator me-1"></i>
                        €@unitPriceText @Model.UnitPriceLabel
                    </div>
                }
            </div>

            <!-- saskaita -->
            <div class="d-flex align-items-center gap-3 mb-3">
                <div class="d-flex align-items-center gap-2">
                    <button type="button" class="btn btn-outline-secondary" id="qtyMinus">
                        <i class="bi bi-dash"></i>
                    </button>

                    <input class="form-control text-center"
                           style="width:80px;"
                           id="qty"
                           value="1"
                           inputmode="numeric" />

                    <button type="button" class="btn btn-outline-secondary" id="qtyPlus">
                        <i class="bi bi-plus"></i>
                    </button>
                </div>

                <div>
                    <div class="small text-muted">
                        <i class="bi bi-receipt me-1"></i>Total
                    </div>
                    <div class="fw-bold fs-5">
                        €<span id="totalPrice">@priceToUseText</span>
                    </div>
                </div>
            </div>

            <!-- pogas -->
            @if (User.Identity != null && User.Identity.IsAuthenticated && User.IsInRole("Admin"))
            {
                <a class="btn btn-outline-primary btn-lg"
                   asp-controller="Admin"
                   asp-action="EditProduct"
                   asp-route-id="@Model.ProductId">
                    <i class="bi bi-pencil-square me-1"></i>
                    Edit product
                </a>
            }
            else
            {
                <form method="post" asp-controller="Cart" asp-action="Add" class="d-flex gap-2">
                    <input type="hidden" name="id" value="@Model.ProductId" />
                    <input type="hidden" id="qtyHidden" name="qty" value="1" />

                    <button class="btn btn-danger btn-lg" type="submit">
                        <i class="bi bi-cart-plus me-1"></i>
                        Pievienot grozam
                    </button>
                </form>
            }
        </div>
    </div>

    <!-- info par produktu tur uzturvertiba utt -->
    <div class="card p-4">
        <h5 class="mb-3">
            <i class="bi bi-info-circle me-1"></i>
            Par produktu
        </h5>

        <div class="row mb-2">
            <div class="col-md-4 text-muted">Ražotājs</div>
            <div class="col-md-8">
                @(Model.Brand != null ? Model.Brand.Name : "—")
            </div>
        </div>

        <div class="row mb-2">
            <div class="col-md-4 text-muted">Papildu informācija</div>
            <div class="col-md-8">
                @if (!string.IsNullOrWhiteSpace(Model.Description))
                {
                    @Model.Description
                }
                else
                {
                    <span class="text-muted">Nav pieejama.</span>
                }
            </div>
        </div>

        <hr />

        <h6 class="mt-3">
            <i class="bi bi-clipboard-data me-1"></i>
            Uzturvērtība (uz 100g/ml)
        </h6>

        <div class="row mb-1">
            <div class="col-md-4 text-muted">Enerģētiskā vērtība</div>
            <div class="col-md-8">
                @(Model.EnergyKj.HasValue || Model.EnergyKcal.HasValue
                    ? $"{Model.EnergyKj ?? 0} kJ / {Model.EnergyKcal ?? 0} kcal"
                    : "—")
            </div>
        </div>

        <div class="row mb-1"><div class="col-md-4 text-muted">Tauki</div><div class="col-md-8">@((Model.FatG.HasValue) ? $"{Model.FatG} g" : "—")</div></div>
        <div class="row mb-1"><div class="col-md-4 text-muted">tostarp piesātinātās taukskābes</div><div class="col-md-8">@((Model.SatFatG.HasValue) ? $"{Model.SatFatG} g" : "—")</div></div>
        <div class="row mb-1"><div class="col-md-4 text-muted">Ogļhidrāti</div><div class="col-md-8">@((Model.CarbsG.HasValue) ? $"{Model.CarbsG} g" : "—")</div></div>
        <div class="row mb-1"><div class="col-md-4 text-muted">tostarp cukuri</div><div class="col-md-8">@((Model.SugarG.HasValue) ? $"{Model.SugarG} g" : "—")</div></div>
        <div class="row mb-1"><div class="col-md-4 text-muted">Olbaltumvielas</div><div class="col-md-8">@((Model.ProteinG.HasValue) ? $"{Model.ProteinG} g" : "—")</div></div>
        <div class="row mb-1"><div class="col-md-4 text-muted">Sāls</div><div class="col-md-8">@((Model.SaltG.HasValue) ? $"{Model.SaltG} g" : "—")</div></div>
    </div>
</div>


<!-- sis saskaita unit cenu un atjauno lapu-->
<script>
    document.addEventListener("DOMContentLoaded", function () {
        const qtyInput = document.getElementById("qty");
        const qtyHidden = document.getElementById("qtyHidden");
        const minusBtn = document.getElementById("qtyMinus");
        const plusBtn = document.getElementById("qtyPlus");
        const totalSpan = document.getElementById("totalPrice");

        const unitPrice = parseFloat("@priceToUseText");

        function getQty() {
            const n = parseInt(qtyInput.value);
            return isNaN(n) || n < 1 ? 1 : n;
        }

        function setQty(n) {
            if (n < 1) n = 1;
            qtyInput.value = n.toString();
            qtyHidden.value = n.toString();
            totalSpan.textContent = (unitPrice * n).toFixed(2);
        }

        minusBtn.addEventListener("click", function () {
            setQty(getQty() - 1);
        });

        plusBtn.addEventListener("click", function () {
            setQty(getQty() + 1);
        });

        qtyInput.addEventListener("input", function () {
            setQty(getQty());
        });

        setQty(1);
    });
</script>
