@model WebstoreProject.Models.Product
@using WebstoreProject.Models

@{
    ViewData["Title"] = "Edit Product";

    List<Brand> brands = ViewBag.Brands as List<Brand> ?? new List<Brand>();
    List<Category> categories = ViewBag.AllCategories as List<Category> ?? new List<Category>();

    string previewUrl = string.IsNullOrWhiteSpace(Model.ImageUrl)
        ? "https://via.placeholder.com/400x300?text=No+Image"
        : Model.ImageUrl;
}

<div class="container mt-4">
    <h2 class="mb-3">Edit Product</h2>

    <form method="post" asp-action="EditProduct" class="card p-3">
        <input type="hidden" name="ProductId" value="@Model.ProductId" />

        <div class="mb-3">
            <label class="form-label">Image preview</label>
            <div class="border rounded p-2 bg-white text-center">
                <img id="imgPreview"
                     src="@previewUrl"
                     alt="Preview"
                     class="img-fluid"
                     style="max-height:260px; object-fit:contain;" />
            </div>
            <div class="form-text">Updates automatically when you change Image URL.</div>
        </div>

        <div class="mb-2">
            <label class="form-label">Name</label>
            <input class="form-control" name="Name" value="@Model.Name" />
        </div>

        <div class="mb-2">
            <label class="form-label">Description</label>
            <textarea class="form-control" name="Description">@Model.Description</textarea>
        </div>

        <div class="row">
            <div class="col-md-4 mb-2">
                <label class="form-label">Price</label>
                <input class="form-control" name="Price" value="@Model.Price" />
            </div>
            <div class="col-md-4 mb-2">
                <label class="form-label">Discount %</label>
                <input class="form-control" name="DiscountPercent" value="@Model.DiscountPercent" />
            </div>
            <div class="col-md-4 mb-2">
                <label class="form-label">Stock</label>
                <input class="form-control" name="StockQty" value="@Model.StockQty" />
            </div>
        </div>

        <div class="mb-2">
            <label class="form-label">Image URL</label>
            <input class="form-control" id="imageUrlInput" name="ImageUrl" value="@Model.ImageUrl" />
        </div>

        <div class="row">
            <div class="col-md-6 mb-2">
                <label class="form-label">Category</label>
                <select class="form-select" name="CategoryId">
                    @foreach (Category c in categories)
                    {
                        if (c.CategoryId == Model.CategoryId)
                        {
                            <option value="@c.CategoryId" selected>@c.Name</option>
                        }
                        else
                        {
                            <option value="@c.CategoryId">@c.Name</option>
                        }
                    }
                </select>
            </div>

            <div class="col-md-6 mb-2">
                <label class="form-label">Brand</label>
                <select class="form-select" name="BrandId">
                    <option value="">(None)</option>
                    @foreach (Brand b in brands)
                    {
                        if (Model.BrandId.HasValue && b.BrandId == Model.BrandId.Value)
                        {
                            <option value="@b.BrandId" selected>@b.Name</option>
                        }
                        else
                        {
                            <option value="@b.BrandId">@b.Name</option>
                        }
                    }
                </select>
            </div>
        </div>

        <div class="row">
            <div class="col-md-6 mb-2">
                <label class="form-label">Unit type</label>
                <select class="form-select" name="UnitType">
                    <option value="pcs" selected="@(Model.UnitType == "pcs")">pcs</option>
                    <option value="g" selected="@(Model.UnitType == "g")">g</option>
                    <option value="kg" selected="@(Model.UnitType == "kg")">kg</option>
                    <option value="ml" selected="@(Model.UnitType == "ml")">ml</option>
                    <option value="l" selected="@(Model.UnitType == "l")">l</option>
                </select>
            </div>

            <div class="col-md-6 mb-2">
                <label class="form-label">Amount per package</label>
                <input class="form-control" name="UnitSize" value="@Model.UnitSize" />
                <div class="form-text">Example: 500 (ml), 200 (g), 1 (kg/l), 10 (pcs).</div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-4 mb-2 d-flex align-items-end">
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" name="IsActive" value="true"
                    @(Model.IsActive ? "checked" : "") />
                    <label class="form-check-label">Active</label>
                </div>
            </div>
        </div>

        <h5 class="mt-4">Nutrition (per 100g/ml)</h5>

        <div class="row">
            <div class="col-md-3 mb-2">
                <label class="form-label">kJ</label>
                <input class="form-control" name="EnergyKj" value="@Model.EnergyKj" />
            </div>
            <div class="col-md-3 mb-2">
                <label class="form-label">kcal</label>
                <input class="form-control" name="EnergyKcal" value="@Model.EnergyKcal" />
            </div>
        </div>

        <div class="row">
            <div class="col-md-3 mb-2"><label class="form-label">Fat (g)</label><input class="form-control" name="FatG" value="@Model.FatG" /></div>
            <div class="col-md-3 mb-2"><label class="form-label">Sat fat (g)</label><input class="form-control" name="SatFatG" value="@Model.SatFatG" /></div>
            <div class="col-md-3 mb-2"><label class="form-label">Carbs (g)</label><input class="form-control" name="CarbsG" value="@Model.CarbsG" /></div>
            <div class="col-md-3 mb-2"><label class="form-label">Sugar (g)</label><input class="form-control" name="SugarG" value="@Model.SugarG" /></div>
        </div>

        <div class="row">
            <div class="col-md-3 mb-2"><label class="form-label">Protein (g)</label><input class="form-control" name="ProteinG" value="@Model.ProteinG" /></div>
            <div class="col-md-3 mb-2"><label class="form-label">Salt (g)</label><input class="form-control" name="SaltG" value="@Model.SaltG" /></div>
        </div>

        <div class="d-flex gap-2 mt-3">
            <button class="btn btn-success" type="submit">Save</button>
            <a class="btn btn-secondary" asp-controller="Admin" asp-action="Index">Cancel</a>
        </div>
    </form>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const input = document.getElementById("imageUrlInput");
        const img = document.getElementById("imgPreview");

        function setPreview(url) {
            if (!url || url.trim().length === 0) {
                img.src = "https://via.placeholder.com/400x300?text=No+Image";
                return;
            }
            img.src = url.trim();
        }

        input.addEventListener("input", function () {
            setPreview(input.value);
        });

        img.addEventListener("error", function () {
            img.src = "https://via.placeholder.com/400x300?text=Image+Not+Found";
        });

        setPreview(input.value);
    });
</script>
