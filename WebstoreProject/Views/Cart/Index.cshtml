@model WebstoreProject.Controllers.CartPage

@{
    ViewData["Title"] = "Cart";
}

<div class="container my-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Cart</h2>
        <a class="btn btn-outline-secondary" asp-controller="Home" asp-action="Index">Atgriezties uz veikalu</a>
    </div>

    @if (Model.Lines.Count == 0)
    {
        <div class="alert alert-info">Grozs ir tukšs.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table align-middle">
                <thead>
                    <tr>
                        <th style="width:90px;">Prece</th>
                        <th>Produkts</th>
                        <th style="width:140px;">Daudzums</th>
                        <th style="width:120px;">Cena</th>
                        <th style="width:140px;">Kopā</th>
                        <th style="width:80px;"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (WebstoreProject.Controllers.CartLineView line in Model.Lines)
                    {
                        <tr>
                            <td>
                                <img class="img-fluid rounded border bg-white"
                                     style="width:72px; height:72px; object-fit:contain;"
                                     src="@(string.IsNullOrWhiteSpace(line.ImageUrl) ? "https://via.placeholder.com/72?text=Item" : line.ImageUrl)" />
                            </td>
                            <td>
                                <div class="fw-semibold">@line.Name</div>
                                <div class="text-muted small">@line.UnitText</div>
                            </td>
                            <td>
                                <form method="post" asp-action="Update" class="d-flex gap-2">
                                    <input type="hidden" name="id" value="@line.ProductId" />
                                    <input class="form-control form-control-sm" name="qty" value="@line.Qty" />
                                    <button class="btn btn-sm btn-outline-primary" type="submit">Atjaunot</button>
                                </form>
                            </td>
                            <td>€@line.UnitPrice.ToString("0.00")</td>
                            <td class="fw-bold">€@line.LineTotal.ToString("0.00")</td>
                            <td>
                                <form method="post" asp-action="Remove">
                                    <input type="hidden" name="id" value="@line.ProductId" />
                                    <button class="btn btn-sm btn-outline-danger" type="submit">X</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="d-flex justify-content-between align-items-center">
            <form method="post" asp-action="Clear">
                <button class="btn btn-outline-danger" type="submit">Iztukšot grozu</button>
            </form>

            <div class="fs-4 fw-bold">
                Total: €@Model.Total.ToString("0.00")
            </div>
        </div>

        <div class="mt-3 text-end">
            <a class="btn btn-danger btn-lg" asp-controller="Checkout" asp-action="Index">Apmaksāt</a>
        </div>
    }
</div>
