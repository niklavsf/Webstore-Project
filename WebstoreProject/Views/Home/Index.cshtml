@model WebstoreProject.Models.HomePage
@using WebstoreProject.Models
@using System.Linq

@{
    ViewData["Title"] = "Home";
}

<div class="container my-3">

    <!-- banner -->
    <div class="mb-4">
        <img src="~/images/groceries_main.webp"
             class="img-fluid rounded w-100"
             style="max-height:320px; object-fit:cover;"
             alt="Promo banner" />
    </div>

    <!-- kategorijas -->
    @foreach (HomeSection homeSection in Model.Sections)
    {
        <div class="d-flex justify-content-between align-items-center mb-2">
            <h4 class="mb-0">@homeSection.TopCategory.Name</h4>
            <a class="text-decoration-none"
               asp-controller="Products"
               asp-action="Index"
               asp-route-categoryId="@homeSection.TopCategory.CategoryId">
                Skatīt vairāk
            </a>
        </div>

        <!-- cards-->
        <div class="row row-cols-2 row-cols-md-3 row-cols-lg-4 g-3 mb-4">
            @foreach (Product p in homeSection.Products.Take(4))
            {
                <div class="col">
                    <div class="card h-100">
                        <a asp-controller="Product"
                           asp-action="Details"
                           asp-route-id="@p.ProductId"
                           class="text-decoration-none text-dark">
                            <img src="@(string.IsNullOrWhiteSpace(p.ImageUrl)
                                ? "https://via.placeholder.com/260x180?text=Product"
                                : p.ImageUrl)"
                                 class="card-img-top"
                                 style="height:160px; object-fit:contain; background:#fff;"
                                 alt="@p.Name" />

                            <div class="card-body">
                                <div class="fw-semibold">@p.Name</div>
                            </div>
                        </a>

                        <div class="card-footer bg-white d-flex justify-content-between align-items-center">
                            @if (p.HasDiscount)
                            {
                                <div>
                                    <span class="text-danger fw-bold">€@p.DiscountedPrice.ToString("0.00")</span>
                                    <span class="text-muted text-decoration-line-through ms-2">€@p.Price.ToString("0.00")</span>
                                </div>
                            }
                            else
                            {
                                <div class="fw-bold">€@p.Price.ToString("0.00")</div>
                            }

                            @if (User.Identity != null && User.Identity.IsAuthenticated && User.IsInRole("Admin"))
                            {
                                <a class="btn btn-sm btn-outline-primary"
                                   asp-controller="Admin"
                                   asp-action="EditProduct"
                                   asp-route-id="@p.ProductId">
                                    Edit
                                </a>
                            }
                            else
                            {
                                <form method="post" asp-controller="Cart" asp-action="Add" class="m-0 p-0">
                                    <input type="hidden" name="id" value="@p.ProductId" />
                                    <input type="hidden" name="qty" value="1" />
                                    <button class="btn btn-sm btn-danger" type="submit">Pievienot</button>
                                </form>
                            }

                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
