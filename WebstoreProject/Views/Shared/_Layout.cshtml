@using WebstoreProject.Models
@using Microsoft.EntityFrameworkCore
@using System.Text.Json
@using Microsoft.AspNetCore.Identity

@inject WebstoreProject.Data.AppDbContext Db
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

@{
    List<Category> menuCategories = await Db.Categories
        .Where(c => c.ParentId == null && c.IsActive)
        .OrderBy(c => c.SortOrder)
        .ThenBy(c => c.Name)
        .Include(c => c.Children.Where(x => x.IsActive).OrderBy(x => x.SortOrder).ThenBy(x => x.Name))
            .ThenInclude(c2 => c2.Children.Where(x => x.IsActive).OrderBy(x => x.SortOrder).ThenBy(x => x.Name))
        .ToListAsync();
}

<!DOCTYPE html>
<html lang="lv">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WebstoreProject</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/WebstoreProject.styles.css" asp-append-version="true" />

    <!-- ikonas -->
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>

<body>
    <header class="border-bottom bg-white">

        <div class="container py-2">
            <!-- logo un meklesana -->
            <div class="row g-2 align-items-center">
                <div class="col-12 col-lg-auto">
                    <a class="navbar-brand fw-bold text-danger" asp-controller="Home" asp-action="Index">
                        NiklavsMart
                    </a>
                </div>

                <div class="col-12 col-lg">
                    <form method="get" asp-controller="Products" asp-action="Index">
                        <div class="input-group">
                            <span class="input-group-text bg-white">
                                <i class="bi bi-search"></i>
                            </span>
                            <input class="form-control"
                                   name="q"
                                   placeholder="Meklēt produktu..."
                                   value="@Context.Request.Query["q"]" />
                            <button class="btn btn-outline-secondary" type="submit">Meklēt</button>
                        </div>
                    </form>
                </div>
            </div>

            <!-- user pogas -->
            <div class="row mt-2">
                <div class="col">
                    <div class="d-flex flex-wrap gap-2 justify-content-start justify-content-lg-end align-items-center">

                        @if (SignInManager.IsSignedIn(User))
                        {
                            <span class="text-muted small d-none d-md-inline">
                                <i class="bi bi-person-circle me-1"></i>@User.Identity!.Name
                            </span>

                            <form method="post" asp-area="Identity" asp-page="/Account/Logout" class="d-inline">
                                <button type="submit" class="btn btn-outline-secondary">
                                    <i class="bi bi-box-arrow-right me-1"></i>Iziet
                                </button>
                            </form>
                        }
                        else
                        {
                            <a class="btn btn-outline-secondary" asp-area="Identity" asp-page="/Account/Login">
                                <i class="bi bi-box-arrow-in-right me-1"></i>Pieslēgties
                            </a>
                            <a class="btn btn-outline-secondary" asp-area="Identity" asp-page="/Account/Register">
                                <i class="bi bi-person-plus me-1"></i>Reģistrēties
                            </a>
                        }

                        <a class="btn btn-outline-dark" asp-controller="Cart" asp-action="Index">
                            <i class="bi bi-cart3 me-1"></i>Grozs
                        </a>

                        @if (User.Identity != null && User.Identity.IsAuthenticated && User.IsInRole("Admin"))
                        {
                            <a class="btn btn-outline-dark" asp-controller="Admin" asp-action="Index">
                                <i class="bi bi-speedometer2 me-1"></i>Admin
                            </a>

                            <a class="btn btn-outline-dark" asp-controller="Admin" asp-action="Index" asp-route-tab="Orders">
                                <i class="bi bi-receipt me-1"></i>Pasūtījumi
                            </a>
                        }
                        else
                        {
                            <a class="btn btn-outline-dark" asp-controller="User" asp-action="Index">
                                <i class="bi bi-person-badge me-1"></i>Mans profils
                            </a>
                        }
                    </div>
                </div>
            </div>
        </div>

        <nav class="navbar navbar-expand-lg navbar-light bg-light">
            <div class="container position-relative">
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNav">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">

                        @if (menuCategories != null && menuCategories.Count > 0)
                        {
                            <li class="nav-item dropdown position-static">
                                <a class="nav-link dropdown-toggle"
                                   href="#"
                                   role="button"
                                   data-bs-toggle="dropdown"
                                   data-bs-auto-close="outside"
                                   data-bs-display="static"
                                   aria-expanded="false">
                                    <i class="bi bi-grid-3x3-gap me-1"></i>Kategorijas
                                </a>

                                <div class="dropdown-menu p-0" style="left:0; right:auto;">

                                    <!-- desktop menu -->
                                    <div id="catDesktopPanel"
                                         class="position-absolute start-0 d-none d-lg-block"
                                         style="width:100%; z-index:1050; background:transparent; border:0; box-shadow:none;">
                                        <div class="container py-3">
                                            <div class="catmenu" style="max-width:960px;">
                                                <div class="catmenu-wrap" id="catMenuRoot">

                                                    <div class="catmenu-col">
                                                        <div class="list-group list-group-flush">
                                                            @foreach (Category top in menuCategories)
                                                            {
                                                                <button type="button"
                                                                        class="list-group-item list-group-item-action catmenu-btn catmenu-top"
                                                                        data-top-id="@top.CategoryId">
                                                                    <span class="d-flex align-items-center gap-2">
                                                                        @if (!string.IsNullOrWhiteSpace(top.IconUrl))
                                                                        {
                                                                            <img src="@top.IconUrl" class="catmenu-icon" />
                                                                        }
                                                                        <span>@top.Name</span>
                                                                    </span>
                                                                    <span class="catmenu-arrow">›</span>
                                                                </button>
                                                            }
                                                        </div>
                                                    </div>

                                                    <div class="catmenu-col d-none" id="catMenuCol2">
                                                        <div class="list-group list-group-flush" id="catMenuSubList"></div>
                                                    </div>

                                                    <div class="catmenu-col d-none" id="catMenuCol3">
                                                        <div class="list-group list-group-flush" id="catMenuLeafList"></div>
                                                    </div>

                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- mobile menu -->
                                    <div class="d-lg-none p-2" style="min-width: 100vw;">
                                        <div class="accordion" id="catAcc">
                                            @foreach (Category top in menuCategories)
                                            {
                                                string topKey = "top" + top.CategoryId;

                                                <div class="accordion-item">
                                                    <h2 class="accordion-header" id="h-@topKey">
                                                        <button class="accordion-button collapsed" type="button"
                                                                data-bs-toggle="collapse"
                                                                data-bs-target="#c-@topKey"
                                                                aria-expanded="false"
                                                                aria-controls="c-@topKey">
                                                            <span class="d-flex align-items-center gap-2">
                                                                @if (!string.IsNullOrWhiteSpace(top.IconUrl))
                                                                {
                                                                    <img src="@top.IconUrl" style="width:20px;height:20px;object-fit:contain;" />
                                                                }
                                                                <span>@top.Name</span>
                                                            </span>
                                                        </button>
                                                    </h2>

                                                    <div id="c-@topKey" class="accordion-collapse collapse" aria-labelledby="h-@topKey" data-bs-parent="#catAcc">
                                                        <div class="accordion-body py-2">
                                                            @if (top.Children != null && top.Children.Count > 0)
                                                            {
                                                                <div class="list-group list-group-flush">
                                                                    @foreach (Category mid in top.Children)
                                                                    {
                                                                        if (mid.Children != null && mid.Children.Count > 0)
                                                                        {
                                                                            string midKey = "mid" + mid.CategoryId;

                                                                            <button class="list-group-item list-group-item-action"
                                                                                    type="button"
                                                                                    data-bs-toggle="collapse"
                                                                                    data-bs-target="#c-@midKey"
                                                                                    aria-expanded="false"
                                                                                    aria-controls="c-@midKey">
                                                                                @mid.Name
                                                                            </button>

                                                                            <div class="collapse" id="c-@midKey">
                                                                                <div class="list-group list-group-flush ms-2">
                                                                                    @foreach (Category leaf in mid.Children)
                                                                                    {
                                                                                        <a class="list-group-item list-group-item-action"
                                                                                           asp-controller="Products"
                                                                                           asp-action="Index"
                                                                                           asp-route-categoryId="@leaf.CategoryId">
                                                                                            @leaf.Name
                                                                                        </a>
                                                                                    }
                                                                                </div>
                                                                            </div>
                                                                        }
                                                                        else
                                                                        {
                                                                            <a class="list-group-item list-group-item-action"
                                                                               asp-controller="Products"
                                                                               asp-action="Index"
                                                                               asp-route-categoryId="@mid.CategoryId">
                                                                                @mid.Name
                                                                            </a>
                                                                        }
                                                                    }
                                                                </div>
                                                            }
                                                            else
                                                            {
                                                                <div class="text-muted">Nav apakškategoriju.</div>
                                                            }
                                                        </div>
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    </div>

                                </div>
                            </li>
                        }

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Info">
                                <i class="bi bi-info-circle me-1"></i>Informācija
                            </a>
                        </li>

                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <div class="row justify-content-center">
            <div class="col-12 col-lg-10 col-xl-9">
                <main role="main" class="pb-3">
                    @RenderBody()
                </main>
            </div>
        </div>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - WebstoreProject -
            <a asp-controller="Home" asp-action="Info" class="text-decoration-none">
                <i class="bi bi-info-circle me-1"></i>Info
            </a>
        </div>
    </footer>

    <script>
        window.CATMENU_DATA = @Html.Raw(JsonSerializer.Serialize(
            menuCategories.Select(t => new
            {
                id = t.CategoryId,
                children = t.Children.Select(m => new
                {
                    id = m.CategoryId,
                    name = m.Name,
                    children = m.Children.Select(l => new
                    {
                        id = l.CategoryId,
                        name = l.Name
                    })
                })
            })
        ));
    </script>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
